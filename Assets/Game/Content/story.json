{
  "schemaVersion": 1,
  "startNodeId": "intro_01",
  "nodes": [
    {
      "id": "intro_01",
      "speaker": "narrator",
      "body": "The mainland boat pulls away. For ninety days, the light is yours alone.",
      "choices": [
        {
          "side": "left",
          "label": "Settle in carefully",
          "effects": [
            { "resource": "supplies", "delta": 1 },
            { "resource": "spirits", "delta": -1 }
          ]
        },
        {
          "side": "right",
          "label": "Light her up tonight",
          "effects": [
            { "resource": "oil", "delta": -2 },
            { "resource": "spirits", "delta": 1 }
          ]
        }
      ]
    },
    {
      "id": "storm",
      "speaker": "narrator",
      "body": "A black storm rolls in. The lamp must burn the whole night through.",
      "choices": [
        {
          "side": "left",
          "label": "Burn extra oil",
          "effects": [
            { "resource": "oil", "delta": -2 },
            { "resource": "health", "delta": -1 }
          ]
        },
        {
          "side": "right",
          "label": "Ration the flame",
          "effects": [
            { "resource": "oil", "delta": -1 },
            { "resource": "spirits", "delta": -1 }
          ]
        }
      ]
    },
    {
      "id": "ship_passing",
      "speaker": "narrator",
      "body": "A freighter's horn moans somewhere out in the fog.",
      "appearWhen": {
        "allOf": [ { "resource": "oil", "op": ">=", "value": 2 } ]
      },
      "choices": [
        {
          "side": "left",
          "label": "Signal her with the lamp",
          "effects": [
            { "resource": "oil", "delta": -1 },
            { "resource": "spirits", "delta": 2 }
          ]
        },
        {
          "side": "right",
          "label": "Let her pass",
          "effects": [
            { "resource": "spirits", "delta": -1 }
          ]
        }
      ]
    },
    {
      "id": "sickness",
      "speaker": "narrator",
      "body": "A fever takes hold in the cold and the damp.",
      "appearWhen": {
        "allOf": [ { "resource": "health", "op": "<=", "value": 4 } ]
      },
      "choices": [
        {
          "side": "left",
          "label": "Rest below the lamp",
          "effects": [
            { "resource": "health", "delta": 2 },
            { "resource": "oil", "delta": -1 }
          ]
        },
        {
          "side": "right",
          "label": "Push through the fever",
          "effects": [
            { "resource": "health", "delta": -1 },
            { "resource": "spirits", "delta": -1 }
          ]
        }
      ]
    },
    {
      "id": "supply_low",
      "speaker": "narrator",
      "body": "The larder is nearly bare. The next boat is weeks away.",
      "appearWhen": {
        "allOf": [ { "resource": "supplies", "op": "<=", "value": 4 } ]
      },
      "choices": [
        {
          "side": "left",
          "label": "Fish from the rocks",
          "effects": [
            { "resource": "supplies", "delta": 2 },
            { "resource": "health", "delta": -1 }
          ]
        },
        {
          "side": "right",
          "label": "Tighten your belt",
          "effects": [
            { "resource": "supplies", "delta": 1 },
            { "resource": "spirits", "delta": -1 }
          ]
        }
      ]
    },
    {
      "id": "loneliness",
      "speaker": "narrator",
      "body": "The silence presses in. You catch yourself talking to the gulls.",
      "appearWhen": {
        "allOf": [ { "resource": "spirits", "op": "<=", "value": 4 } ]
      },
      "choices": [
        {
          "side": "left",
          "label": "Fill the keeper's log",
          "effects": [
            { "resource": "spirits", "delta": 2 }
          ]
        },
        {
          "side": "right",
          "label": "Stare from the gallery",
          "effects": [
            { "resource": "spirits", "delta": -1 },
            { "resource": "health", "delta": -1 }
          ]
        }
      ]
    },
    {
      "id": "inspector",
      "speaker": "narrator",
      "body": "Against all odds, an inspection cutter ties up at the jetty.",
      "choices": [
        {
          "side": "left",
          "label": "Show a spotless log",
          "effects": [
            { "resource": "spirits", "delta": 1 },
            { "resource": "supplies", "delta": -1 }
          ]
        },
        {
          "side": "right",
          "label": "Beg them for more oil",
          "effects": [
            { "resource": "oil", "delta": 3 },
            { "resource": "spirits", "delta": -1 }
          ]
        }
      ]
    }
  ],
  "endings": [
    { "when": { "resource": "oil", "edge": "min" }, "text": "The lamp gutters and dies. In the dark, a hull splinters on the rocks below." },
    { "when": { "resource": "supplies", "edge": "min" }, "text": "The larder is empty. Hunger finishes what the sea began." },
    { "when": { "resource": "health", "edge": "min" }, "text": "Fever and damp take their toll. The relief boat finds the light still burning, and you cold beside it." },
    { "when": { "resource": "spirits", "edge": "min" }, "text": "The silence wins. One grey dawn you walk down to the water and keep walking." },
    { "fallback": true, "text": "The relief boat returns on the ninetieth day. The light never failed once. You did your duty." }
  ]
}
